@{
    var path = Context?.Request?.Path.Value ?? string.Empty;
    bool isHome = path == "/";
    bool isProducts = path.StartsWith("/Home/Products", StringComparison.OrdinalIgnoreCase);
    bool isCart = path.StartsWith("/Home/Cart", StringComparison.OrdinalIgnoreCase);
    bool isCheckout = path.StartsWith("/Home/Checkout", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Winter Elegance</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="store-body">
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>

    <header class="store-header">
        <div class="container">
            <div class="topbar-pill">
                <span>Free ship nội thành cho đơn từ 799.000đ</span>
                <span class="topbar-divider"></span>
                <span>Đổi size trong 7 ngày</span>
            </div>

            <nav class="navbar navbar-expand-lg store-navbar">
                <a class="navbar-brand store-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">WE</span>
                    <span>
                        <strong>Winter Elegance</strong>
                        <small>Winter Collection</small>
                    </span>
                </a>

                <button class="navbar-toggler border-0 shadow-none px-0" type="button" data-bs-toggle="collapse" data-bs-target="#storeNav">
                    <i class="bi bi-list fs-1 text-light"></i>
                </button>

                <div class="collapse navbar-collapse" id="storeNav">
                    <ul class="navbar-nav mx-auto store-nav-links">
                        <li class="nav-item">
                            <a class="nav-link @(isHome ? "active" : string.Empty)" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isProducts ? "active" : string.Empty)" asp-controller="Home" asp-action="Products">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#story">Bộ sưu tập</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#service">Dịch vụ</a>
                        </li>
                    </ul>

                    <div class="store-nav-actions">
                        <a class="icon-action" asp-controller="Home" asp-action="Products" aria-label="Tìm sản phẩm">
                            <i class="bi bi-search"></i>
                        </a>
                        <a class="cart-action @(isCart || isCheckout ? "active" : string.Empty)" asp-controller="Home" asp-action="Cart">
                            <i class="bi bi-bag-heart"></i>
                            <span>Giỏ hàng</span>
                            <span id="cartBadge" class="cart-badge">0</span>
                        </a>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <main class="store-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3"></div>

    <footer class="store-footer" id="service">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <p class="footer-eyebrow">Winter Elegance</p>
                    <h3>Phong cách mùa đông được tuyển chọn cho nhịp sống hiện đại.</h3>
                    <p class="footer-copy">
                        Những thiết kế ấm áp, tinh giản và dễ ứng dụng để bạn luôn tự tin trong mọi khoảnh khắc mùa lạnh.
                    </p>
                </div>
                <div>
                    <p class="footer-title">Liên hệ</p>
                    <ul class="footer-list">
                        <li>Hotline: 0988 888 888</li>
                        <li>Email: hello@winterelegance.vn</li>
                        <li>Giờ hỗ trợ: 08:00 - 22:00</li>
                    </ul>
                </div>
                <div>
                    <p class="footer-title">Cam kết</p>
                    <ul class="footer-list">
                        <li>Giao nhanh nội thành</li>
                        <li>Kiểm hàng trước khi nhận</li>
                        <li>Hỗ trợ đổi size dễ dàng</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>&copy; 2026 Winter Elegance.</span>
                <span>Curated winter essentials.</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
