@{
    var path = Context?.Request?.Path.Value ?? string.Empty;
    bool isHome = path == "/" || path.StartsWith("/Home/Index", StringComparison.OrdinalIgnoreCase);
    bool isProducts = path.StartsWith("/Home/Products", StringComparison.OrdinalIgnoreCase) || path.StartsWith("/Home/Details", StringComparison.OrdinalIgnoreCase);
    bool isCart = path.StartsWith("/Home/Cart", StringComparison.OrdinalIgnoreCase);
    bool isCheckout = path.StartsWith("/Home/Checkout", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Winter Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="pos-body">
    <div class="pos-app">
        <aside class="sidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <span class="sidebar-brand-title">WINTER SHOP</span>
            </a>

            <nav class="sidebar-nav">
                <a class="sidebar-link @(isProducts ? "active" : string.Empty)" asp-controller="Home" asp-action="Products">
                    <i class="bi bi-basket"></i>
                    <span>Bán hàng</span>
                </a>
                <a class="sidebar-link @(isCart ? "active" : string.Empty)" asp-controller="Home" asp-action="Cart">
                    <i class="bi bi-cart3"></i>
                    <span>Quản lý đơn hàng</span>
                    <span id="cartBadge" class="sidebar-badge">0</span>
                </a>
                <a class="sidebar-link @(isHome ? "active" : string.Empty)" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-people"></i>
                    <span>Khách hàng</span>
                </a>
                <a class="sidebar-link" asp-controller="Home" asp-action="Products">
                    <i class="bi bi-handbag"></i>
                    <span>Sản phẩm</span>
                </a>
                <a class="sidebar-link @(isCheckout ? "active" : string.Empty)" asp-controller="Home" asp-action="Checkout">
                    <i class="bi bi-credit-card"></i>
                    <span>Thanh toán</span>
                </a>
                
            </nav>
        </aside>

        <div class="workspace">
            <header class="workspace-header">
                <div class="workspace-meta-left">
                    <span>Cửa hàng: Khu vực A - Hà Nội</span>
                </div>
                <div class="workspace-meta-right">
                    @{
                        // Kiểm tra xem người dùng đã đăng nhập chưa
                        var userId = Context.Session.GetString("UserId");
                        var userEmail = Context.Session.GetString("UserEmail"); // Ta sẽ thêm cái này ở Controller
                    }
                    @if (string.IsNullOrEmpty(userId))
                    {
                        <a href="/Account/Login" class="btn btn-sm btn-outline-dark fw-bold">Đăng nhập</a>
                        <a href="/Account/Register" class="btn btn-sm btn-dark fw-bold">Đăng ký</a>
                    }
                    else
                    {
                        <span class="text-primary fw-bold">
                            <i class="bi bi-person-circle"></i> @(string.IsNullOrEmpty(userEmail) ? "Nhân viên" : userEmail)
                        </span>
                        <a href="/Account/Logout" class="btn btn-sm btn-danger fw-bold" title="Đăng xuất">
                            <i class="bi bi-box-arrow-right"></i> Thoát
                        </a>
                    }
                    <span class="text-muted border-start ps-3 ms-2">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                    <span class="text-muted fw-bold">@DateTime.Now.ToString("HH:mm")</span>                    
                </div>
            </header>

            <main class="workspace-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="site-footer">
        <div class="site-footer-inner">
            <span>Winter Shop</span>
        </div>
    </footer>

    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
