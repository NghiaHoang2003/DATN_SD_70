<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Winter Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="store-body">
    <header class="store-header">
        <div class="container store-header-inner">
            <a class="store-logo" asp-controller="Home" asp-action="Index">Winter Shop</a>

            <nav class="store-nav" aria-label="Danh mục chính">
                <div class="nav-item has-submenu">
                    <a class="nav-link" asp-controller="Home" asp-action="Products" asp-route-category="outerwear">Áo khoác ngoài</a>
                    <div class="nav-submenu">
                        <a asp-controller="Home" asp-action="Products" asp-route-category="outerwear" asp-route-subcategory="ao-phao">Áo phao</a>
                        <a asp-controller="Home" asp-action="Products" asp-route-category="outerwear" asp-route-subcategory="ao-da">Áo da</a>
                        <a asp-controller="Home" asp-action="Products" asp-route-category="outerwear" asp-route-subcategory="mang-to">Măng tô</a>
                    </div>
                </div>
                <div class="nav-item has-submenu">
                    <a class="nav-link" asp-controller="Home" asp-action="Products" asp-route-category="short-jacket">Áo khoác ngắn</a>
                    <div class="nav-submenu">
                        <a asp-controller="Home" asp-action="Products" asp-route-category="short-jacket" asp-route-subcategory="ao-khoac-ngan">Áo khoác ngắn</a>
                        <a asp-controller="Home" asp-action="Products" asp-route-category="short-jacket" asp-route-subcategory="gile">Gile phao</a>
                    </div>
                </div>
                <div class="nav-item has-submenu">
                    <a class="nav-link" asp-controller="Home" asp-action="Products" asp-route-category="layering">Áo len layer</a>
                    <div class="nav-submenu">
                        <a asp-controller="Home" asp-action="Products" asp-route-category="layering" asp-route-subcategory="ao-len">Áo len</a>
                        <a asp-controller="Home" asp-action="Products" asp-route-category="layering" asp-route-subcategory="hoodie">Hoodie</a>
                    </div>
                </div>
                <div class="nav-item has-submenu">
                    <a class="nav-link" asp-controller="Home" asp-action="Products" asp-route-category="heattech">Áo giữ nhiệt</a>
                    <div class="nav-submenu">
                        <a asp-controller="Home" asp-action="Products" asp-route-category="heattech" asp-route-subcategory="giu-nhiet">Áo giữ nhiệt</a>
                    </div>
                </div>
            </nav>

            <div class="store-actions">
                <div class="header-search">
                    <button id="headerSearchToggle" type="button" class="icon-button" aria-label="Tìm kiếm">
                        <i class="bi bi-search"></i>
                    </button>
                    <div class="header-search-panel">
                        <label class="visually-hidden" for="headerSearchInput">Tìm kiếm sản phẩm</label>
                        <input id="headerSearchInput" type="search" class="header-search-input" placeholder="Tìm kiếm sản phẩm..." />
                        <div id="headerSearchResults" class="header-search-results">
                            <div class="header-search-empty">Nhập tên sản phẩm để tìm.</div>
                        </div>
                    </div>
                </div>

                <div class="account-menu">
                    <button type="button" class="icon-button" aria-label="Tài khoản">
                        <i class="bi bi-person"></i>
                    </button>
                    <div class="account-dropdown">
                        <a href="#">Đăng nhập</a>
                        <a href="#">Đăng ký</a>
                        <a href="#">Tra cứu đơn hàng</a>
                    </div>
                </div>

                <div class="cart-menu">
                    <a class="icon-button cart-trigger" asp-controller="Home" asp-action="Cart" aria-label="Giỏ hàng">
                        <i class="bi bi-bag"></i>
                        <span id="cartBadge" class="cart-badge">0</span>
                    </a>
                    <div class="cart-preview">
                        <div class="cart-preview-head">
                            <strong>Giỏ hàng</strong>
                            <span id="cartPreviewCount">0 sản phẩm</span>
                        </div>
                        <div id="cartPreviewItems" class="cart-preview-items">
                            <div class="cart-preview-empty">Giỏ hàng đang trống.</div>
                        </div>
                        <div class="cart-preview-actions">
                            <a class="btn btn-dark-soft" asp-controller="Home" asp-action="Cart">Xem giỏ hàng</a>
                            <a class="btn btn-brand" asp-controller="Home" asp-action="Checkout">Thanh toán</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="store-main">
        @RenderBody()
    </main>

    <footer class="store-footer">
        <div class="container store-footer-grid">
            <div>
                <div class="store-footer-brand">Winter Shop</div>
                <p class="footer-copy">Thời trang mùa đông tập trung vào áo khoác, áo len layer và các mẫu mặc hằng ngày dễ phối.</p>
            </div>
            <div>
                <h4>Hỗ trợ</h4>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Hướng dẫn mua hàng</a>
            </div>
            <div>
                <h4>Thanh toán</h4>
                <div class="footer-badges">
                    <span>VNPAY</span>
                    <span>Visa</span>
                    <span>COD</span>
                </div>
            </div>
            <div>
                <h4>Vận chuyển</h4>
                <div class="footer-badges">
                    <span>VNPost</span>
                    <span>GHTK</span>
                    <span>Freeship</span>
                </div>
            </div>
        </div>
    </footer>

    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
