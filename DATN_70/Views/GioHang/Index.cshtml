@{
    ViewData["Title"] = "Giỏ hàng";
}

<section class="cart-shell">
    <div class="page-head">
        <div>
            <span class="page-tag">Shopping Bag</span>
            <h1 class="page-title">Giỏ hàng của bạn</h1>
            <p class="page-copy">Người dùng có thể chỉnh số lượng, xóa sản phẩm và theo dõi tổng tiền trước khi sang bước thanh toán.</p>
        </div>
    </div>

    <div class="cart-layout">
        <div class="cart-panel">
            <h4 class="cart-title">Danh sách sản phẩm</h4>
            <div id="cartItemsContainer"></div>
        </div>

        <aside class="summary-panel">
            <h4 class="summary-title">Tóm tắt đơn hàng</h4>
            <div class="summary-list">
                <div class="summary-row">
                    <span>Tạm tính</span>
                    <strong id="subtotalAmount">0 đ</strong>
                </div>
                <div class="summary-row">
                    <span>Phí vận chuyển</span>
                    <span>Miễn phí</span>
                </div>
                <div class="summary-row summary-total">
                    <span>Tổng cộng</span>
                    <span id="totalAmount">0 đ</span>
                </div>
            </div>
            <a id="checkoutLink" class="btn btn-brand checkout-submit" asp-controller="Home" asp-action="Checkout">Tiến hành thanh toán</a>
        </aside>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const cartItemsContainer = document.getElementById("cartItemsContainer");
            const subtotalAmount = document.getElementById("subtotalAmount");
            const totalAmount = document.getElementById("totalAmount");
            const checkoutLink = document.getElementById("checkoutLink");

            function syncCheckoutState(cart) {
                const disabled = cart.length === 0;
                checkoutLink.classList.toggle("disabled", disabled);
                checkoutLink.style.pointerEvents = disabled ? "none" : "auto";
                checkoutLink.style.opacity = disabled ? "0.6" : "1";
            }

            function renderCart() {
                const cart = window.winterCart.getCart();
                const subtotal = window.winterCart.getSubtotal(cart);
                subtotalAmount.textContent = window.winterCart.formatCurrency(subtotal);
                totalAmount.textContent = window.winterCart.formatCurrency(subtotal);
                syncCheckoutState(cart);

                if (!cart.length) {
                    cartItemsContainer.innerHTML = `
                        <div class="empty-state">
                            Giỏ hàng đang trống. Hãy thêm vài sản phẩm để test tiếp luồng đặt hàng.
                            <div class="inline-actions justify-content-center">
                                <a class="btn btn-dark-soft" href="/Home/Products">Mở trang sản phẩm</a>
                            </div>
                        </div>`;
                    return;
                }

                cartItemsContainer.innerHTML = cart.map(item => `
                    <article class="cart-item">
                        <div class="thumb-wrap">
                            ${window.winterStore.buildArtwork({ sanPhamID: item.sanPhamID }, "card")}
                        </div>
                        <div>
                            <a class="item-name" href="/Home/Details?id=${encodeURIComponent(item.sanPhamID || "")}">${window.winterStore.escapeHtml(item.tenSanPham)}</a>
                            <div class="item-meta">${window.winterStore.escapeHtml(item.phanLoai)}</div>
                            <div class="qty-actions">
                                <input class="store-input qty-input cart-quantity-input" type="number" min="1" step="1" value="${item.soLuong}" data-id="${item.chiTietSanPhamID}" />
                                <button type="button" class="link-button cart-remove-btn" data-id="${item.chiTietSanPhamID}">Xóa</button>
                            </div>
                        </div>
                        <strong class="price-amount">${window.winterCart.formatCurrency(item.donGia * item.soLuong)}</strong>
                    </article>
                `).join("");
            }

            checkoutLink.addEventListener("click", function (event) {
                if (window.winterCart.getCart().length > 0) {
                    return;
                }
                event.preventDefault();
                window.winterCart.showToast("Giỏ hàng đang trống.", "warning");
            });

            cartItemsContainer.addEventListener("change", function (event) {
                if (!event.target.classList.contains("cart-quantity-input")) {
                    return;
                }
                const quantity = Number.parseInt(event.target.value, 10);
                if (!Number.isInteger(quantity) || quantity < 1) {
                    event.target.value = 1;
                }
                window.winterCart.updateQuantity(event.target.dataset.id, event.target.value);
                renderCart();
            });

            cartItemsContainer.addEventListener("click", function (event) {
                const button = event.target.closest(".cart-remove-btn");
                if (!button) {
                    return;
                }
                window.winterCart.removeItem(button.dataset.id);
                window.winterCart.showToast("Đã xóa sản phẩm khỏi giỏ hàng.", "success");
                renderCart();
            });

            window.addEventListener("winterCartChanged", renderCart);
            renderCart();
        });
    </script>
}
