@{
    ViewData["Title"] = "Thanh toán";
}

<h3 class="fw-bold mb-4 mt-4">Thông tin giao hàng</h3>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <form>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-bold">Họ và tên người nhận</label>
                        <input id="customerName" type="text" class="form-control form-control-lg rounded-3" placeholder="Nhập họ tên đầy đủ">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input id="customerPhone" type="tel" class="form-control form-control-lg rounded-3" placeholder="09xx xxx xxx">
                        <small id="phoneHelp" class="text-muted">Ví dụ: 0912345678 hoặc +84912345678</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Email</label>
                        <input id="customerEmail" type="email" class="form-control form-control-lg rounded-3" placeholder="email@example.com">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                        <input id="customerAddress" type="text" class="form-control form-control-lg rounded-3" placeholder="Số nhà, đường, phường/xã, quận/huyện...">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold">Ghi chú (Tùy chọn)</label>
                        <textarea class="form-control rounded-3" rows="2" placeholder="Ghi chú thêm về thời gian giao hàng..."></textarea>
                    </div>

                    <h5 class="fw-bold mt-4 mb-2">Phương thức thanh toán</h5>
                    <div class="col-12">
                        <div class="form-check p-3 border rounded-3 mb-2 bg-light">
                            <input class="form-check-input ms-1" type="radio" name="payment" id="cod" checked>
                            <label class="form-check-label ms-2 fw-bold" for="cod">
                                Thanh toán khi nhận hàng (COD)
                            </label>
                        </div>
                        <div class="form-check p-3 border rounded-3">
                            <input class="form-check-input ms-1" type="radio" name="payment" id="bank">
                            <label class="form-check-label ms-2 fw-bold" for="bank">
                                Chuyển khoản ngân hàng
                            </label>
                        </div>
                    </div>
                </div>
                <button id="btnPlaceOrder" type="button" class="btn btn-success btn-lg w-100 mt-4 fw-bold py-3 rounded-pill shadow">ĐẶT HÀNG NGAY</button>
            </form>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 bg-light p-4">
            <h5 id="checkoutItemCount" class="fw-bold mb-4">Đơn hàng của bạn (0)</h5>
            <div id="checkoutItems"></div>

            <hr class="text-muted">

            <div class="d-flex justify-content-between mb-2 text-muted">
                <span>Tạm tính</span>
                <span id="checkoutSubtotal">0 đ</span>
            </div>
            <div class="d-flex justify-content-between mb-3 text-muted">
                <span>Phí vận chuyển</span>
                <span>0 đ</span>
            </div>
            <hr>
            <div class="d-flex justify-content-between fs-5">
                <span class="fw-bold">Tổng thanh toán:</span>
                <span id="checkoutTotal" class="fw-bold text-danger">0 đ</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnPlaceOrder = document.getElementById('btnPlaceOrder');
            const checkoutItems = document.getElementById('checkoutItems');
            const checkoutItemCount = document.getElementById('checkoutItemCount');
            const checkoutSubtotal = document.getElementById('checkoutSubtotal');
            const checkoutTotal = document.getElementById('checkoutTotal');
            const customerName = document.getElementById('customerName');
            const customerPhone = document.getElementById('customerPhone');
            const customerAddress = document.getElementById('customerAddress');
            const phoneHelp = document.getElementById('phoneHelp');

            function setPhoneError(message) {
                customerPhone.classList.add('is-invalid');
                phoneHelp.className = 'text-danger';
                phoneHelp.textContent = message;
            }

            function clearPhoneError() {
                customerPhone.classList.remove('is-invalid');
                phoneHelp.className = 'text-muted';
                phoneHelp.textContent = 'Ví dụ: 0912345678 hoặc +84912345678';
            }

            function validateCheckoutForm() {
                if (!customerName.value.trim() || !customerAddress.value.trim()) {
                    window.winterCart.showToast("Vui lòng điền đầy đủ thông tin giao hàng.", "warning");
                    return false;
                }

                if (!window.winterCart.isValidPhoneNumber(customerPhone.value)) {
                    setPhoneError('Số điện thoại không đúng định dạng.');
                    window.winterCart.showToast("Số điện thoại không hợp lệ.", "warning");
                    return false;
                }

                clearPhoneError();
                return true;
            }

            function renderCheckoutSummary() {
                const cart = window.winterCart.getCart();

                if (cart.length === 0) {
                    window.winterCart.showToast("Giỏ hàng của bạn đang trống.", "warning");
                    window.location.href = '/Home/Cart';
                    return [];
                }

                checkoutItemCount.textContent = `Đơn hàng của bạn (${window.winterCart.getTotalQuantity(cart)})`;
                checkoutSubtotal.textContent = window.winterCart.formatCurrency(window.winterCart.getSubtotal(cart));
                checkoutTotal.textContent = window.winterCart.formatCurrency(window.winterCart.getSubtotal(cart));

                checkoutItems.innerHTML = cart.map(item => `
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center">
                            <img src="https://placehold.co/50x60/e9ecef/495057?text=${encodeURIComponent(item.tenSanPham)}" class="rounded me-3" alt="${item.tenSanPham}">
                            <div>
                                <h6 class="mb-0 fw-bold">${item.tenSanPham}</h6>
                                <small class="text-muted">SL: ${item.soLuong} | ${item.phanLoai}</small>
                            </div>
                        </div>
                        <span class="fw-bold">${window.winterCart.formatCurrency(item.donGia * item.soLuong)}</span>
                    </div>`).join('');

                return cart;
            }

            customerPhone.addEventListener('input', function () {
                if (window.winterCart.isValidPhoneNumber(customerPhone.value)) {
                    clearPhoneError();
                }
            });

            renderCheckoutSummary();

            btnPlaceOrder.addEventListener('click', async function () {
                const cart = window.winterCart.getCart();

                if (cart.length === 0) {
                    window.winterCart.showToast("Giỏ hàng của bạn đang trống.", "warning");
                    window.location.href = '/Home/Cart';
                    return;
                }

                if (!validateCheckoutForm()) {
                    return;
                }

                const requestData = {
                    tenKhachHang: customerName.value.trim(),
                    soDienThoai: customerPhone.value.replace(/\s+/g, ''),
                    diaChiGiaoHang: customerAddress.value.trim(),
                    items: cart.map(item => ({
                        chiTietSanPhamID: item.chiTietSanPhamID,
                        soLuong: item.soLuong
                    }))
                };

                try {
                    btnPlaceOrder.innerText = "Đang xử lý...";
                    btnPlaceOrder.disabled = true;

                    const response = await fetch('/api/orders', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(requestData)
                    });

                    if (response.ok) {
                        const result = await response.json();
                        window.winterCart.clear();
                        window.winterCart.showToast(`Đặt hàng thành công. Mã đơn: ${result.hoaDonID}`, "success");
                        setTimeout(function () {
                            window.location.href = '/';
                        }, 900);
                        return;
                    }

                    const error = await response.json();
                    window.winterCart.showToast(error.message || "Kiểm tra lại dữ liệu nhập.", "danger");
                } catch (error) {
                    console.error("Lỗi khi gọi API:", error);
                    window.winterCart.showToast("Lỗi kết nối đến máy chủ.", "danger");
                } finally {
                    btnPlaceOrder.innerText = "ĐẶT HÀNG NGAY";
                    btnPlaceOrder.disabled = false;
                }
            });
        });
    </script>
}
