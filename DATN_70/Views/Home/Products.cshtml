@{
    ViewData["Title"] = "Bán hàng";
}

<section class="sales-shell">
    <div class="sales-layout">
        <div class="sales-main">
            <div class="sales-toolbar">
                <div class="toolbar-view-buttons">
                    <button type="button" class="view-toggle active" aria-label="Dạng lưới">
                        <i class="bi bi-grid-3x3-gap-fill"></i>
                    </button>
                    <button type="button" class="view-toggle" aria-label="Dạng danh sách">
                        <i class="bi bi-list-ul"></i>
                    </button>
                </div>

                <input id="mobileSearchInput" class="search-field" type="text" placeholder="Tìm hàng" />

                <div class="sales-pages">
                    <button type="button" class="pager-chip active">1</button>
                    <button type="button" class="pager-chip">2</button>
                    <button type="button" class="pager-chip">3</button>
                    <button type="button" class="pager-chip">4</button>
                </div>
            </div>

            <div class="sales-filter-strip">
                <div class="sales-filter-block">
                    <label class="control-label" for="searchInput">Tìm theo tên</label>
                    <input id="searchInput" class="search-field" type="text" placeholder="Nhập tên hoặc mã sản phẩm" />
                </div>

                <div class="sales-filter-block grow">
                    <label class="control-label">Nhóm sản phẩm</label>
                    <div id="categoryChips" class="chip-row"></div>
                </div>

                <div class="sales-filter-block sales-filter-stock">
                    <label class="control-label" for="sortSelect">Sắp xếp</label>
                    <select id="sortSelect" class="store-select" aria-label="Sắp xếp sản phẩm">
                        <option value="featured">Nổi bật</option>
                        <option value="price-asc">Giá tăng dần</option>
                        <option value="price-desc">Giá giảm dần</option>
                        <option value="stock-desc">Tồn kho nhiều</option>
                        <option value="name-asc">Tên A-Z</option>
                    </select>
                </div>

                <div class="sales-filter-block sales-filter-stock">
                    <label class="control-label">Tồn kho</label>
                    <button id="stockToggle" type="button" class="chip-button">Còn nhiều hàng</button>
                </div>
            </div>

            <div id="resultSummary" class="result-summary">Đang tải dữ liệu sản phẩm...</div>

            <div id="catalogGrid" class="product-grid">
                <div class="loading-state">
                    <div class="spinner-border" role="status"></div>
                    <p class="mt-3 mb-0">Đang tải danh sách sản phẩm...</p>
                </div>
            </div>
        </div>

        <aside class="sales-cart">
            <div class="sales-cart-head">
                <h3>Giỏ hàng của bạn</h3>
                <a class="sales-cart-link" asp-controller="Home" asp-action="Cart">Mở chi tiết</a>
            </div>

            <div class="sales-cart-search">
                <input class="search-field" type="text" placeholder="Nhập tên hoặc số điện thoại" />
                <button type="button" class="icon-square" aria-label="Khách hàng">
                    <i class="bi bi-person-plus"></i>
                </button>
            </div>

            <div id="salesCartItems" class="sales-cart-items">
                <div class="empty-state">Chưa có sản phẩm trong giỏ hàng.</div>
            </div>

            <div class="sales-cart-summary">
                <div class="summary-row">
                    <span>Tạm tính:</span>
                    <strong id="salesSubtotal">0 đ</strong>
                </div>
                <div class="summary-row">
                    <span>Thuế VAT:</span>
                    <span>-10,000 đ</span>
                </div>
                <div class="summary-row sales-total">
                    <span>Thành tiền:</span>
                    <strong id="salesTotal">0 đ</strong>
                </div>
            </div>

            <div class="sales-cart-actions">
                <button id="salesClearCart" type="button" class="btn btn-danger-soft">Xóa toàn bộ</button>
                <a class="btn btn-brand" asp-controller="Home" asp-action="Checkout">Thanh toán</a>
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", async function () {
            const catalogGrid = document.getElementById("catalogGrid");
            const resultSummary = document.getElementById("resultSummary");
            const searchInput = document.getElementById("searchInput");
            const mobileSearchInput = document.getElementById("mobileSearchInput");
            const sortSelect = document.getElementById("sortSelect");
            const categoryChips = document.getElementById("categoryChips");
            const stockToggle = document.getElementById("stockToggle");
            const salesCartItems = document.getElementById("salesCartItems");
            const salesSubtotal = document.getElementById("salesSubtotal");
            const salesTotal = document.getElementById("salesTotal");
            const salesClearCart = document.getElementById("salesClearCart");

            let products = [];
            let selectedCategory = "all";
            let stockOnly = false;

            function syncSearch(value) {
                searchInput.value = value;
                mobileSearchInput.value = value;
            }

            function renderCategories(items) {
                const categories = ["all", ...new Set(items.map(item => item.meta.category))];
                categoryChips.innerHTML = categories.map(category => {
                    const label = category === "all" ? "Tất cả" : category;
                    const activeClass = category === selectedCategory ? "active" : "";
                    return `<button type="button" class="chip-button ${activeClass}" data-category="${window.winterStore.escapeHtml(category)}">${window.winterStore.escapeHtml(label)}</button>`;
                }).join("");
            }

            function renderSalesCart() {
                const cart = window.winterCart.getCart();
                const subtotal = window.winterCart.getSubtotal(cart);
                salesSubtotal.textContent = window.winterCart.formatCurrency(subtotal);
                salesTotal.textContent = window.winterCart.formatCurrency(Math.max(subtotal - 10000, 0));

                if (!cart.length) {
                    salesCartItems.innerHTML = '<div class="empty-state">Chưa có sản phẩm trong giỏ hàng.</div>';
                    return;
                }

                salesCartItems.innerHTML = cart.map(item => `
                    <article class="sales-cart-item">
                        <div class="sales-cart-thumb">
                            ${window.winterStore.buildArtwork({ sanPhamID: item.sanPhamID }, "card")}
                        </div>
                        <div class="sales-cart-info">
                            <strong>${window.winterStore.escapeHtml(item.tenSanPham)}</strong>
                            <span>${window.winterStore.escapeHtml(item.phanLoai)}</span>
                            <div class="sales-cart-meta">
                                <span>SL ${item.soLuong}</span>
                                <span>${window.winterCart.formatCurrency(item.donGia * item.soLuong)}</span>
                            </div>
                        </div>
                    </article>
                `).join("");
            }

            function applyFilters() {
                const keyword = searchInput.value.trim().toLowerCase();
                let filtered = products.filter(product => {
                    const matchesKeyword = !keyword || product.ten.toLowerCase().includes(keyword) || product.meta.category.toLowerCase().includes(keyword);
                    const matchesCategory = selectedCategory === "all" || product.meta.category === selectedCategory;
                    const matchesStock = !stockOnly || product.tongSoLuongTon >= 10;
                    return matchesKeyword && matchesCategory && matchesStock;
                });

                switch (sortSelect.value) {
                    case "price-asc":
                        filtered.sort((a, b) => a.giaThapNhat - b.giaThapNhat);
                        break;
                    case "price-desc":
                        filtered.sort((a, b) => b.giaThapNhat - a.giaThapNhat);
                        break;
                    case "stock-desc":
                        filtered.sort((a, b) => b.tongSoLuongTon - a.tongSoLuongTon);
                        break;
                    case "name-asc":
                        filtered.sort((a, b) => a.ten.localeCompare(b.ten, "vi"));
                        break;
                    default:
                        filtered.sort((a, b) => b.tongSoLuongTon - a.tongSoLuongTon);
                        break;
                }

                resultSummary.textContent = `Hiển thị ${filtered.length} sản phẩm`;
                catalogGrid.innerHTML = filtered.length
                    ? filtered.map(window.winterStore.renderProductCard).join("")
                    : '<div class="empty-state">Không có sản phẩm phù hợp.</div>';
            }

            searchInput.addEventListener("input", function () {
                syncSearch(searchInput.value);
                applyFilters();
            });

            mobileSearchInput.addEventListener("input", function () {
                syncSearch(mobileSearchInput.value);
                applyFilters();
            });

            sortSelect.addEventListener("change", applyFilters);

            categoryChips.addEventListener("click", function (event) {
                const button = event.target.closest("[data-category]");
                if (!button) {
                    return;
                }

                selectedCategory = button.dataset.category;
                renderCategories(products);
                applyFilters();
            });

            stockToggle.addEventListener("click", function () {
                stockOnly = !stockOnly;
                stockToggle.classList.toggle("active", stockOnly);
                applyFilters();
            });

            salesClearCart.addEventListener("click", function () {
                if (!window.winterCart.getCart().length) {
                    return;
                }

                window.winterCart.clear();
                renderSalesCart();
                window.winterCart.showToast("Đã xóa toàn bộ giỏ hàng.", "success");
            });

            window.addEventListener("winterCartChanged", renderSalesCart);

            try {
                products = await window.winterStore.fetchProducts();
                renderCategories(products);
                applyFilters();
                renderSalesCart();
            } catch (error) {
                console.error(error);
                resultSummary.textContent = "Lỗi tải dữ liệu.";
                catalogGrid.innerHTML = '<div class="empty-state">Không thể tải danh sách sản phẩm.</div>';
                renderSalesCart();
            }
        });
    </script>
}
