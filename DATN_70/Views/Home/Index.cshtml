@{
    ViewData["Title"] = "Trang chủ";
}

<section id="homePage" class="page-section home-page">
    <div class="container">
        <section class="hero-banner">
            <div class="hero-frame">
                <div class="hero-copy">
                    <span class="eyebrow-text">Bộ sưu tập mở bán</span>
                    <h1>Tưng bừng khai trương.<br />Giảm giá sập sàn.</h1>
                    <p>Áo khoác mùa lạnh, áo len layer và các mẫu mặc hằng ngày dành cho đơn hàng online.</p>
                    <div class="hero-actions">
                        <a class="btn btn-dark-soft" asp-controller="Home" asp-action="Products">Mua ngay</a>
                        <a class="btn btn-ghost-dark" asp-controller="Home" asp-action="Products" asp-route-category="outerwear">Xem áo khoác ngoài</a>
                    </div>
                </div>
                <div class="hero-visuals">
                    <div class="hero-art-grid">
                        <div class="mini-art" data-product="SP0001"></div>
                        <div class="mini-art" data-product="SP0003"></div>
                        <div class="mini-art" data-product="SP0004"></div>
                        <div class="mini-art" data-product="SP0006"></div>
                    </div>
                    <div class="hero-discounts">
                        <span>40%</span>
                        <span>60%</span>
                        <span>70%</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="home-block">
            <div class="section-heading">
                <h2>Danh mục</h2>
            </div>
            <div id="homeCategories" class="category-row"></div>
        </section>

        <section class="home-block promo-shelf">
            <div class="section-heading">
                <h2>Sản phẩm ưu đãi sâu</h2>
                <a asp-controller="Home" asp-action="Products">Xem tất cả</a>
            </div>
            <div id="homeFeaturedProducts" class="product-row">
                <div class="empty-state">Đang tải sản phẩm khuyến mãi...</div>
            </div>
        </section>

        <section class="home-block">
            <div class="section-heading">
                <h2>Danh mục phụ</h2>
            </div>
            <div id="homeTabs" class="tab-strip"></div>
            <div id="homeTabProducts" class="product-row large-grid">
                <div class="empty-state">Đang tải sản phẩm...</div>
            </div>
            <div class="center-action">
                <a class="pill-link" asp-controller="Home" asp-action="Products">Xem tất cả sản phẩm</a>
            </div>
        </section>
    </div>
</section>
