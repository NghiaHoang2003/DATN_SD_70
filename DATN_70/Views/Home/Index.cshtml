@model DATN_70.Models.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Trang chủ";
    var banners = Model?.Banners ?? new List<DATN_70.Models.ViewModels.HomeBannerViewModel>();
}

<section id="homePage" class="page-section home-page" data-banner-count="@banners.Count">
    <div class="container">
        <section class="hero-banner @(banners.Count > 1 ? "is-slideshow" : "is-static")" data-interval="7000">
            @if (banners.Count == 0)
            {
                <div class="empty-state">Chưa có banner nào được kích hoạt.</div>
            }
            else
            {
                <div class="hero-banner-track">
                    @for (var i = 0; i < banners.Count; i++)
                    {
                        var banner = banners[i];
                        <article class="hero-slide @(i == 0 ? "active" : string.Empty)" data-slide-index="@i">
                            <a class="hero-slide-link" href="@banner.LinkUrl">
                                <img src="@banner.ImageUrl" alt="@banner.Title" class="hero-slide-image" />
                                <div class="hero-slide-overlay">
                                    <div class="hero-slide-topline">
                                        <span class="eyebrow-text">Winter Shop</span>
                                        <span class="hero-slide-index">@(i + 1).0@(banners.Count)</span>
                                    </div>
                                    <div class="hero-slide-copy">
                                        <h1>@banner.Title</h1>
                                        @if (!string.IsNullOrWhiteSpace(banner.Description))
                                        {
                                            <p>@banner.Description</p>
                                        }
                                    </div>
                                    <div class="hero-slide-actions">
                                        <span class="btn btn-brand">Khám phá ngay</span>
                                        <span class="hero-slide-meta">Lookbook mùa lạnh được quản lý trực tiếp từ dashboard</span>
                                    </div>
                                </div>
                            </a>
                        </article>
                    }
                </div>
                @if (banners.Count > 1)
                {
                    <div class="hero-banner-nav" aria-label="Banner controls">
                        <button type="button" class="hero-nav-button" data-slide-direction="prev" aria-label="Banner truoc">
                            <span>&larr;</span>
                        </button>
                        <button type="button" class="hero-nav-button" data-slide-direction="next" aria-label="Banner tiep theo">
                            <span>&rarr;</span>
                        </button>
                    </div>
                    <div class="hero-dots" aria-label="Banner dots">
                        @for (var i = 0; i < banners.Count; i++)
                        {
                            <button type="button" class="hero-dot @(i == 0 ? "active" : string.Empty)" data-slide-to="@i" aria-label="Banner @(i + 1)"></button>
                        }
                    </div>
                }
            }
        </section>

        <section class="home-feature-grid">
            <article class="home-feature-card">
                <strong>Giao dien mua nhanh</strong>
                <p>Chon mau, size va them gio hang nhanh tren storefront, khong can di qua qua nhieu lop man hinh.</p>
            </article>
            <article class="home-feature-card">
                <strong>Checkout gon hon</strong>
                <p>Khach da dang nhap co the lay san thong tin ho so va dia chi mac dinh khi thanh toan.</p>
            </article>
            <article class="home-feature-card">
                <strong>Theo doi don ro rang</strong>
                <p>Trang thai don hang duoc tach theo tung moc de nguoi mua theo doi lai de dang.</p>
            </article>
        </section>

        <section class="home-block">
            <div class="section-heading">
                <div>
                    <h2>Danh muc noi bat</h2>
                    <p class="section-subtitle">Đi thẳng vào nhóm sản phẩm bán tốt trong mùa lạnh.</p>
                </div>
            </div>
            <div id="homeCategories" class="category-row"></div>
        </section>

        <section class="home-block promo-shelf">
            <div class="section-heading">
                <div>
                    <h2>Sản phẩm ưu đãi sâu</h2>
                    <p class="section-subtitle">Chỉ hiển thị các sản phẩm đang có khuyến mãi thực sự trong database.</p>
                </div>
                <a asp-controller="Home" asp-action="Products">Xem tất cả</a>
            </div>
            <div id="homeFeaturedProducts" class="product-row product-row-fixed">
                <div class="empty-state">Đang tải sản phẩm khuyến mãi...</div>
            </div>
        </section>

        <section class="home-block">
            <div class="section-heading">
                <div>
                    <h2>Mặc theo nhu cầu</h2>
                    <p class="section-subtitle">Chuyển nhanh giữa các nhóm áo khoác, layer và đồ giữ nhiệt để lọc hàng phù hợp.</p>
                </div>
            </div>
            <div id="homeTabs" class="tab-strip"></div>
            <div id="homeTabProducts" class="product-row product-row-fixed large-grid">
                <div class="empty-state">Đang tải sản phẩm...</div>
            </div>
            <div class="center-action">
                <a class="pill-link" asp-controller="Home" asp-action="Products">Xem tất cả sản phẩm</a>
            </div>
        </section>
    </div>
</section>
