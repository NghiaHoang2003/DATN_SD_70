@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="card border-0 shadow-sm rounded-4 p-4 mt-4">
    <div class="row">
        <div class="col-md-5 text-center mb-3 mb-md-0">
            <img src="https://placehold.co/500x600/e9ecef/495057?text=Ao+Khoac+Phao" class="img-fluid rounded-3 shadow-sm" alt="Áo khoác">
        </div>

        <div class="col-md-7 pt-2">
            <span class="badge bg-dark mb-2">Hàng mới về</span>
            <h2 class="fw-bold" id="productName">Áo Khoác Phao Dáng Dài Cao Cấp</h2>
            <h3 class="text-danger fw-bold my-3" id="productPrice">1,250,000 đ</h3>
            <p class="text-muted lh-lg" id="productDesc">Áo khoác phao siêu nhẹ, giữ nhiệt cực tốt. Phù hợp cho nhiệt độ dưới 10 độ C. Lớp ngoài chống nước nhẹ, bên trong chần bông gòn tự nhiên đảm bảo sự ấm áp tuyệt đối cho mùa đông năm nay.</p>
            <p class="small text-muted" id="productStock">Đang tải tồn kho...</p>

            <hr class="my-4 text-muted">

            <form>
                <div class="row mb-4">
                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">Chọn Phân loại</label>
                        <select id="variantSelect" class="form-select form-select-lg rounded-3">
                            <option disabled selected>Đang tải phân loại...</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Số lượng</label>
                        <input id="quantityInput" type="number" class="form-control form-control-lg rounded-3" value="1" min="1" step="1">
                        <small id="quantityHelp" class="text-muted">Nhập từ 1 sản phẩm trở lên.</small>
                    </div>
                </div>

                <button id="btnAddToCart" type="button" class="btn btn-primary btn-lg w-100 py-3 fw-bold rounded-pill shadow-sm">
                    <i class="bi bi-cart-plus me-2"></i> THÊM VÀO GIỎ HÀNG
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", async function () {
            const urlParams = new URLSearchParams(window.location.search);
            const productId = urlParams.get('id');
            const select = document.getElementById('variantSelect');
            const priceElement = document.getElementById('productPrice');
            const stockElement = document.getElementById('productStock');
            const quantityInput = document.getElementById('quantityInput');
            const quantityHelp = document.getElementById('quantityHelp');
            const btnAdd = document.getElementById('btnAddToCart');
            let variants = [];

            if (!productId) {
                window.winterCart.showToast("Không tìm thấy mã sản phẩm.", "danger");
                window.location.href = '/';
                return;
            }

            function getSelectedVariant() {
                return variants.find(x => x.chiTietSanPhamID === select.value) || null;
            }

            function setQuantityError(message) {
                quantityInput.classList.add('is-invalid');
                quantityHelp.className = 'text-danger';
                quantityHelp.textContent = message;
            }

            function clearQuantityError() {
                quantityInput.classList.remove('is-invalid');
                quantityHelp.className = 'text-muted';
                quantityHelp.textContent = 'Nhập từ 1 sản phẩm trở lên.';
            }

            function getValidQuantity(maxStock) {
                const rawValue = quantityInput.value.trim();
                const parsed = Number(rawValue);

                if (!Number.isInteger(parsed) || parsed < 1) {
                    setQuantityError('Số lượng phải là số nguyên lớn hơn hoặc bằng 1.');
                    return null;
                }

                if (maxStock > 0 && parsed > maxStock) {
                    setQuantityError(`Số lượng không được vượt quá tồn kho (${maxStock}).`);
                    quantityInput.value = maxStock;
                    return null;
                }

                clearQuantityError();
                return parsed;
            }

            function updateVariantDisplay() {
                const selectedVariant = getSelectedVariant();
                if (!selectedVariant) {
                    priceElement.innerText = 'Liên hệ';
                    stockElement.innerText = 'Hiện chưa có biến thể khả dụng.';
                    return;
                }

                priceElement.innerText = window.winterCart.formatCurrency(selectedVariant.giaNiemYet);
                stockElement.innerText = `Còn lại ${selectedVariant.soLuongTon} sản phẩm trong kho.`;
                quantityInput.max = Math.max(selectedVariant.soLuongTon, 1);

                if (selectedVariant.soLuongTon > 0 && Number(quantityInput.value) > selectedVariant.soLuongTon) {
                    quantityInput.value = selectedVariant.soLuongTon;
                }

                clearQuantityError();
            }

            try {
                const response = await fetch(`/api/products/${productId}`);

                if (!response.ok) {
                    document.getElementById('productName').innerText = "Sản phẩm không tồn tại.";
                    stockElement.innerText = "Không thể tải tồn kho sản phẩm.";
                    btnAdd.disabled = true;
                    return;
                }

                const product = await response.json();

                document.getElementById('productName').innerText = product.ten;
                document.getElementById('productDesc').innerText = product.moTa;
                select.innerHTML = '';
                variants = Array.isArray(product.bienThe) ? product.bienThe : [];

                if (variants.length === 0) {
                    select.innerHTML = '<option disabled>Hết hàng</option>';
                    priceElement.innerText = 'Hết hàng';
                    stockElement.innerText = 'Sản phẩm hiện chưa có biến thể nào để bán.';
                    btnAdd.disabled = true;
                    return;
                }

                variants.forEach(variant => {
                    const option = document.createElement('option');
                    option.value = variant.chiTietSanPhamID;
                    option.text = `Màu ${variant.tenMau} - Size ${variant.tenKichCo}`;
                    select.appendChild(option);
                });

                updateVariantDisplay();
            } catch (error) {
                console.error("Lỗi khi tải chi tiết:", error);
                stockElement.innerText = "Không thể tải dữ liệu sản phẩm.";
                btnAdd.disabled = true;
                return;
            }

            select.addEventListener('change', updateVariantDisplay);
            quantityInput.addEventListener('input', function () {
                const selectedVariant = getSelectedVariant();
                getValidQuantity(selectedVariant ? selectedVariant.soLuongTon : 0);
            });

            btnAdd.addEventListener('click', function () {
                const selectedVariant = getSelectedVariant();

                if (!selectedVariant) {
                    window.winterCart.showToast("Vui lòng chọn phân loại sản phẩm.", "warning");
                    return;
                }

                if (selectedVariant.soLuongTon <= 0) {
                    window.winterCart.showToast("Biến thể này đã hết hàng.", "danger");
                    return;
                }

                const quantity = getValidQuantity(selectedVariant.soLuongTon);
                if (!quantity) {
                    window.winterCart.showToast("Vui lòng nhập số lượng hợp lệ.", "warning");
                    return;
                }

                window.winterCart.addItem({
                    chiTietSanPhamID: selectedVariant.chiTietSanPhamID,
                    tenSanPham: document.getElementById('productName').innerText,
                    phanLoai: `${selectedVariant.tenMau} - ${selectedVariant.tenKichCo}`,
                    soLuong: quantity,
                    donGia: selectedVariant.giaNiemYet
                });

                window.winterCart.showToast("Đã thêm vào giỏ hàng thành công.", "success");
            });
        });
    </script>
}
